{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://islamicatlas.org/schema/canonical/route.schema.json",
  "title": "Route",
  "description": "Bir kanonik yol / güzergah (ticaret yolu, seyahat, hac rotası, askerî sefer yolu, bilgi transfer hattı). CIDOC-CRM: E53 Place (linear extent) / E9 Move.",
  "type": "object",
  "required": ["id", "slug", "names", "route_type"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^rte_[a-z0-9_-]+$",
      "description": "Kanonik ID — örnek: rte_silk_road_main, rte_ibn_battuta_rihla, rte_hajj_darb_al_kufa"
    },
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"},
    "names": {
      "type": "object",
      "properties": {
        "tr": {"type": "string"},
        "en": {"type": "string"},
        "ar": {"type": "string"},
        "ar_translit": {"type": "string"}
      },
      "minProperties": 1
    },
    "route_type": {
      "type": "string",
      "enum": [
        "trade_route",
        "pilgrimage_route",
        "travel_itinerary",
        "military_campaign",
        "knowledge_transfer",
        "postal",
        "diplomatic",
        "migration",
        "crusade_march"
      ]
    },
    "mode": {
      "type": "string",
      "enum": ["land", "sea", "river", "mixed"],
      "description": "Güzergah modu"
    },
    "waypoints": {
      "type": "array",
      "description": "Yol üzerindeki duraklar — sıralı",
      "items": {
        "type": "object",
        "required": ["order"],
        "properties": {
          "order": {"type": "integer", "minimum": 0},
          "place_id": {"type": "string", "pattern": "^plc_"},
          "coordinates": {
            "type": "object",
            "description": "Place ID yoksa doğrudan koordinat",
            "properties": {
              "lat": {"type": "number"},
              "lon": {"type": "number"}
            }
          },
          "arrival_date_ce": {"type": "integer"},
          "departure_date_ce": {"type": "integer"},
          "stay_duration_days": {"type": "integer"},
          "note": {"type": "string"}
        }
      },
      "minItems": 2
    },
    "geometry": {
      "type": "object",
      "description": "GeoJSON LineString (API cevabı için önceden hesaplanmış)",
      "properties": {
        "type": {"const": "LineString"},
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "number"},
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "chronology": {
      "type": "object",
      "properties": {
        "active_start_ce": {"type": "integer"},
        "active_end_ce": {"type": "integer"},
        "journey_start_ce": {"type": "integer"},
        "journey_end_ce": {"type": "integer"},
        "peak_period_start_ce": {"type": "integer"},
        "peak_period_end_ce": {"type": "integer"}
      }
    },
    "traveler": {
      "type": "array",
      "description": "Seyahat / sefer güzergahı ise seyyah/kumandan bilgisi",
      "items": {
        "type": "object",
        "properties": {
          "person_id": {"type": "string", "pattern": "^per_"},
          "role": {"type": "string", "examples": ["traveler", "commander", "envoy", "pilgrim", "scholar"]}
        }
      }
    },
    "associated_dynasty_ids": {
      "type": "array",
      "description": "Sefer/postal yolu ise ilgili hanedanlar",
      "items": {"type": "string", "pattern": "^dyn_"}
    },
    "goods": {
      "type": "array",
      "description": "Ticaret yolu ise taşınan mallar",
      "items": {
        "type": "string",
        "examples": ["silk", "spices", "slaves", "horses", "gold", "paper", "books", "ceramics", "timber", "salt"]
      }
    },
    "distance_km": {"type": "number"},
    "duration_days_approx": {"type": "integer"},
    "source_document_ids": {
      "type": "array",
      "description": "Bu yolun kaynağı (Rihla metni, Divanı vb.) — Work ID'leri",
      "items": {"type": "string", "pattern": "^wrk_"}
    },
    "attestations": {
      "type": "array",
      "items": {"type": "string", "pattern": "^att_"}
    },
    "sameAs": {
      "type": "object",
      "properties": {
        "wikidata": {"type": "string", "pattern": "^Q[0-9]+$"}
      }
    },
    "description": {
      "type": "object",
      "properties": {
        "tr": {"type": "string", "maxLength": 5000},
        "en": {"type": "string", "maxLength": 5000}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string", "enum": ["verified", "needs_review", "disputed", "provisional"]},
    "version": {"type": "integer"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "legacy_ids": {
      "type": "object",
      "properties": {
        "trade_route_id": {"type": ["integer", "string"]},
        "voyage_id": {"type": ["integer", "string"]},
        "ibn_battuta_voyage_id": {"type": ["integer", "string"]},
        "evliya_voyage_id": {"type": ["integer", "string"]},
        "salibiyyat_route_id": {"type": ["integer", "string"]},
        "science_route_id": {"type": ["integer", "string"]}
      }
    }
  }
}
