{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://islamicatlas.org/schema/canonical/person.schema.json",
  "title": "Person",
  "description": "Bir kanonik kişi (âlim, hükümdar, müellif, şair, komutan). CIDOC-CRM: E21 Person. schema.org: Person.",
  "type": "object",
  "required": ["id", "slug", "names"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^per_[a-z0-9_-]+$",
      "description": "Kanonik ID — örnek: per_al_khwarizmi, per_ibn_sina, per_tabari"
    },
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"},
    "names": {
      "type": "object",
      "required": [],
      "properties": {
        "kunya": {"type": "string", "description": "Künye (ör. Ebû Nasr)"},
        "ism": {"type": "string", "description": "Esas ad"},
        "nasab": {"type": "string", "description": "Soy silsilesi (b. ... b. ...)"},
        "laqab": {"type": "string", "description": "Lakap (ör. el-Fârâbî)"},
        "nisba": {"type": "array", "items": {"type": "string"}, "description": "Nisbeler (ör. el-Bağdâdî, el-Harezmî)"},
        "shuhra": {"type": "string", "description": "Meşhur olduğu ad"},
        "tr": {"type": "string", "description": "Türkçe'de en yaygın kullanılan form"},
        "en": {"type": "string", "description": "İngilizce'de en yaygın kullanılan form"},
        "ar": {"type": "string", "description": "Arapça özgün biçim"},
        "ar_translit": {"type": "string"}
      },
      "minProperties": 1
    },
    "name_variants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "form": {"type": "string"},
          "language": {"type": "string"},
          "source_id": {"type": "string"}
        }
      }
    },
    "gender": {"type": "string", "enum": ["M", "F", "unknown"]},
    "chronology": {
      "type": "object",
      "properties": {
        "birth_year_ce": {"type": "integer"},
        "birth_year_hijri": {"type": "integer"},
        "birth_year_uncertain": {"type": "boolean"},
        "death_year_ce": {"type": "integer"},
        "death_year_hijri": {"type": "integer"},
        "death_year_uncertain": {"type": "boolean"},
        "flourished_start_ce": {"type": "integer"},
        "flourished_end_ce": {"type": "integer"},
        "century_ce": {"type": "integer", "minimum": 1, "maximum": 21}
      }
    },
    "places": {
      "type": "object",
      "description": "Kişinin coğrafi ilişkileri — Place canonical ID'leri",
      "properties": {
        "birth_place_id": {"type": "string", "pattern": "^plc_"},
        "death_place_id": {"type": "string", "pattern": "^plc_"},
        "active_place_ids": {"type": "array", "items": {"type": "string", "pattern": "^plc_"}},
        "burial_place_id": {"type": "string", "pattern": "^plc_"}
      }
    },
    "profession": {
      "type": "array",
      "description": "Meslek / uzmanlık alanı — controlled vocabulary: scholar, ruler, jurist, theologian, poet, physician, astronomer, mathematician, historian, commander, mystic, grammarian, philosopher, translator, merchant",
      "items": {"type": "string"}
    },
    "fields": {
      "type": "array",
      "description": "Çalışma alanı — fiqh, hadith, tafsir, kalam, tasawwuf, falsafa, astronomy, mathematics, medicine, geography, history, adab, linguistics",
      "items": {"type": "string"}
    },
    "madhab": {
      "type": "string",
      "description": "Mezhebî aidiyet — hanefi, shafii, maliki, hanbali, shii_imami, shii_ismaili, zaydi, ibadi, mu_tazili, ashari, maturidi",
      "examples": ["hanefi", "shafii", "maliki"]
    },
    "relations": {
      "type": "object",
      "description": "Prosopografik ilişkiler — SILSILE",
      "properties": {
        "teachers": {"type": "array", "items": {"type": "string", "pattern": "^per_"}},
        "students": {"type": "array", "items": {"type": "string", "pattern": "^per_"}},
        "father_id": {"type": "string", "pattern": "^per_"},
        "mother_id": {"type": "string", "pattern": "^per_"},
        "children_ids": {"type": "array", "items": {"type": "string", "pattern": "^per_"}},
        "patrons": {"type": "array", "items": {"type": "string", "pattern": "^(per|dyn)_"}},
        "patronized": {"type": "array", "items": {"type": "string", "pattern": "^per_"}},
        "contemporaries": {"type": "array", "items": {"type": "string", "pattern": "^per_"}}
      }
    },
    "works": {
      "type": "array",
      "description": "Yazdığı eserlerin canonical ID listesi",
      "items": {"type": "string", "pattern": "^wrk_"}
    },
    "dynasty_affiliation": {
      "type": "array",
      "description": "Hizmet ettiği / döneminde yaşadığı hanedanlar",
      "items": {"type": "string", "pattern": "^dyn_"}
    },
    "attestations": {
      "type": "array",
      "items": {"type": "string", "pattern": "^att_"}
    },
    "sameAs": {
      "type": "object",
      "properties": {
        "wikidata": {"type": "string", "pattern": "^Q[0-9]+$"},
        "viaf": {"type": "string"},
        "gnd": {"type": "string"},
        "orcid": {"type": "string"},
        "dia_url": {"type": "string", "format": "uri"}
      }
    },
    "biography": {
      "type": "object",
      "properties": {
        "tr": {"type": "string", "maxLength": 10000},
        "en": {"type": "string", "maxLength": 10000},
        "ar": {"type": "string", "maxLength": 10000}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["verified", "needs_review", "disputed", "provisional", "merged"]
    },
    "version": {"type": "integer"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "legacy_ids": {
      "type": "object",
      "properties": {
        "alam_id": {"type": ["integer", "string"]},
        "dia_id": {"type": "string"},
        "ei1_id": {"type": ["integer", "string"]},
        "science_layer_id": {"type": "string"},
        "ruler_id": {"type": ["integer", "string"]},
        "scholar_id": {"type": ["integer", "string"]},
        "gas_id": {"type": "string"},
        "openiti_author_uri": {"type": "string"}
      }
    }
  }
}
