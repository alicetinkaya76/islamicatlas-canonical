{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://islamicatlas.org/schema/canonical/place.schema.json",
  "title": "Place",
  "description": "Bir kanonik coğrafi yer. Pleiades Place modelinden ilham alınmıştır. CIDOC-CRM: E53 Place. schema.org: Place.",
  "type": "object",
  "required": ["id", "slug", "names"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^plc_[a-z0-9_-]+$",
      "description": "Kanonik ID — değiştirilemez, URI temeli. Örnek: plc_baghdad, plc_konya, plc_samarqand"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$",
      "description": "URL segmenti — islamicatlas.org/place/{slug}"
    },
    "names": {
      "type": "object",
      "description": "Kanonik ad — tercih edilen formlar",
      "properties": {
        "tr": {"type": "string"},
        "en": {"type": "string"},
        "ar": {"type": "string"},
        "ar_translit": {"type": "string", "description": "IJMES veya DİN 31635 standardı"},
        "primary_lang": {"type": "string", "description": "Hangi dil tercih edilen ad?"}
      },
      "minProperties": 1
    },
    "name_variants": {
      "type": "array",
      "description": "Kaynaklarda geçen tüm ad varyantları — attestation'dan agregat",
      "items": {
        "type": "object",
        "properties": {
          "form": {"type": "string"},
          "language": {"type": "string"},
          "script": {"type": "string", "enum": ["arabic", "latin", "ottoman", "persian", "cyrillic"]},
          "period_start_ce": {"type": "integer"},
          "period_end_ce": {"type": "integer"},
          "attestation_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "place_type": {
      "type": "array",
      "description": "Yer tipi — taksonomi: city, town, village, region, iqlim, well, mountain, river, route, monastery, fortress, mosque, madrasa, bimaristan, mint, battlefield",
      "items": {"type": "string"}
    },
    "geography": {
      "type": "object",
      "description": "Kanonik coğrafi konum — birden fazla kaynaktaki iddianın birleştirilmiş hâli",
      "properties": {
        "canonical_coordinates": {
          "type": "object",
          "properties": {
            "lat": {"type": "number", "minimum": -90, "maximum": 90},
            "lon": {"type": "number", "minimum": -180, "maximum": 180},
            "precision_meters": {"type": "integer"},
            "source": {
              "type": "string",
              "description": "Hangi kaynak/yöntem kanonik kabul edildi",
              "examples": ["wikidata", "le_strange", "modern_geocoder", "manual"]
            }
          }
        },
        "bbox": {
          "type": "object",
          "properties": {
            "north": {"type": "number"},
            "south": {"type": "number"},
            "east": {"type": "number"},
            "west": {"type": "number"}
          }
        },
        "modern_country": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[A-Z]{2}$", "description": "ISO 3166-1 alpha-2"}
        },
        "iqlim": {
          "type": "array",
          "description": "Ortaçağ İslam coğrafyasında iqlim aidiyeti",
          "items": {"type": "string"}
        },
        "historical_region": {"type": "array", "items": {"type": "string"}}
      }
    },
    "chronology": {
      "type": "object",
      "description": "Yerin tarihsel zaman dilimleri",
      "properties": {
        "founding_ce": {"type": "integer"},
        "founding_hijri": {"type": "integer"},
        "abandonment_ce": {"type": "integer"},
        "flourished_periods": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start_ce": {"type": "integer"},
              "end_ce": {"type": "integer"},
              "label": {"type": "string"}
            }
          }
        }
      }
    },
    "relations": {
      "type": "object",
      "description": "Diğer varlıklarla ilişkiler — graf kenarları",
      "properties": {
        "contains": {"type": "array", "items": {"type": "string"}, "description": "İçerdiği yerler (plc_id)"},
        "within": {"type": "array", "items": {"type": "string"}, "description": "İçinde olduğu yer"},
        "near": {"type": "array", "items": {"type": "string"}},
        "successor": {"type": "string", "description": "Yerini alan yeni yer"},
        "predecessor": {"type": "string", "description": "Bu yerin üstüne kurulduğu eski yer"},
        "capital_of_dynasty": {"type": "array", "items": {"type": "string"}}
      }
    },
    "attestations": {
      "type": "array",
      "description": "Bu Place'e ait attestation ID listesi",
      "items": {"type": "string", "pattern": "^att_"}
    },
    "sameAs": {
      "type": "object",
      "description": "Linked Open Data bağlantıları — FAIR ilkesi",
      "properties": {
        "wikidata": {"type": "string", "pattern": "^Q[0-9]+$"},
        "pleiades": {"type": "string", "format": "uri"},
        "geonames": {"type": "string"},
        "viaf": {"type": "string"},
        "dia_url": {"type": "string", "format": "uri"}
      }
    },
    "description": {
      "type": "object",
      "properties": {
        "tr": {"type": "string", "maxLength": 5000},
        "en": {"type": "string", "maxLength": 5000},
        "ar": {"type": "string", "maxLength": 5000}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}},
    "importance": {"type": "string", "enum": ["kritik", "yuksek", "normal", "dusuk"]},
    "status": {
      "type": "string",
      "enum": ["verified", "needs_review", "disputed", "provisional"]
    },
    "version": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "legacy_ids": {
      "type": "object",
      "description": "Phase 0 öncesi legacy katmanlarda bu Place'i işaret eden ID'ler — migration izi",
      "properties": {
        "yaqut_id": {"type": ["integer", "string"]},
        "le_strange_id": {"type": ["integer", "string"]},
        "dia_id": {"type": "string"},
        "ei1_id": {"type": ["integer", "string"]},
        "muqaddasi_id": {"type": "string"},
        "konya_id": {"type": "string"},
        "cairo_id": {"type": "string"},
        "darpislam_id": {"type": "string"}
      }
    }
  }
}
