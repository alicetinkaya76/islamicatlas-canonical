{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://islamicatlas.org/schema/canonical/event.schema.json",
  "title": "Event",
  "description": "Bir kanonik tarihsel olay (savaş, fetih, isyan, inşa, seyahat, diplomatik anlaşma, suikast). CIDOC-CRM: E5 Event. schema.org: Event.",
  "type": "object",
  "required": ["id", "slug", "titles", "event_type"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^evt_[a-z0-9_-]+$",
      "description": "Kanonik ID — örnek: evt_battle_manzikert_1071, evt_fall_baghdad_1258, evt_fetih_istanbul_1453"
    },
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"},
    "titles": {
      "type": "object",
      "properties": {
        "tr": {"type": "string"},
        "en": {"type": "string"},
        "ar": {"type": "string"},
        "ar_translit": {"type": "string"}
      },
      "minProperties": 1
    },
    "event_type": {
      "type": "array",
      "description": "Olay tipi — controlled vocabulary",
      "items": {
        "type": "string",
        "enum": [
          "battle", "siege", "conquest", "revolt", "uprising", "assassination",
          "death", "birth", "accession", "abdication", "appointment", "dismissal",
          "construction", "destruction", "earthquake", "fire", "plague", "famine",
          "treaty", "embassy", "marriage", "pilgrimage", "council",
          "translation", "composition", "publication",
          "foundation_of_institution", "migration", "journey", "expedition",
          "crusade", "mongol_invasion", "ridda", "fitna"
        ]
      },
      "minItems": 1
    },
    "chronology": {
      "type": "object",
      "description": "Tarih — en azından bir başlangıç tarihi olmalı",
      "properties": {
        "start_ce": {"type": "integer"},
        "start_hijri": {"type": "integer"},
        "start_month": {"type": "integer", "minimum": 1, "maximum": 12},
        "start_day": {"type": "integer", "minimum": 1, "maximum": 31},
        "end_ce": {"type": "integer"},
        "end_hijri": {"type": "integer"},
        "end_month": {"type": "integer", "minimum": 1, "maximum": 12},
        "end_day": {"type": "integer", "minimum": 1, "maximum": 31},
        "duration_days_approx": {"type": "integer"},
        "uncertain": {"type": "boolean"},
        "uncertainty_range_years": {"type": "integer"}
      }
    },
    "location": {
      "type": "object",
      "description": "Olayın geçtiği yer(ler)",
      "properties": {
        "primary_place_id": {"type": "string", "pattern": "^plc_"},
        "all_place_ids": {"type": "array", "items": {"type": "string", "pattern": "^plc_"}},
        "coordinates_override": {
          "type": "object",
          "description": "Olay noktası Place'in merkezinden farklıysa (ör. savaş alanı şehrin dışında)",
          "properties": {
            "lat": {"type": "number"},
            "lon": {"type": "number"}
          }
        },
        "region": {"type": "string"}
      }
    },
    "participants": {
      "type": "object",
      "description": "Olaya katılan varlıklar — taraflar + rolleri",
      "properties": {
        "dynasties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dynasty_id": {"type": "string", "pattern": "^dyn_"},
              "role": {
                "type": "string",
                "enum": ["attacker", "defender", "victor", "vanquished", "ally", "vassal", "neutral", "mediator"]
              }
            }
          }
        },
        "persons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "person_id": {"type": "string", "pattern": "^per_"},
              "role": {
                "type": "string",
                "examples": ["commander", "caliph", "sultan", "ambassador", "victim", "assassin", "founder", "participant"]
              },
              "side": {"type": "string"}
            }
          }
        },
        "external_entities": {
          "type": "array",
          "description": "Kanonik varlığa bağlanmamış, yalnız metinle anılan taraflar (ör. 'Bizans ordusu')",
          "items": {"type": "string"}
        }
      }
    },
    "outcome": {
      "type": "object",
      "properties": {
        "result": {
          "type": "string",
          "enum": ["decisive_victory", "victory", "pyrrhic_victory", "stalemate", "defeat", "inconclusive", "n/a"]
        },
        "casualties_approx": {"type": "integer"},
        "territorial_change": {"type": "string"},
        "political_consequence": {"type": "string"},
        "summary_tr": {"type": "string"},
        "summary_en": {"type": "string"}
      }
    },
    "causal_relations": {
      "type": "object",
      "description": "Diğer olaylarla nedensel/kronolojik bağlar — Salibiyyat katmanındaki causal_links",
      "properties": {
        "caused_by": {"type": "array", "items": {"type": "string", "pattern": "^evt_"}},
        "leads_to": {"type": "array", "items": {"type": "string", "pattern": "^evt_"}},
        "concurrent_with": {"type": "array", "items": {"type": "string", "pattern": "^evt_"}},
        "responds_to": {"type": "array", "items": {"type": "string", "pattern": "^evt_"}}
      }
    },
    "importance": {
      "type": "string",
      "enum": ["kritik", "yuksek", "normal", "dusuk"]
    },
    "attestations": {
      "type": "array",
      "items": {"type": "string", "pattern": "^att_"}
    },
    "sameAs": {
      "type": "object",
      "properties": {
        "wikidata": {"type": "string", "pattern": "^Q[0-9]+$"},
        "dbpedia": {"type": "string"},
        "dia_url": {"type": "string", "format": "uri"}
      }
    },
    "description": {
      "type": "object",
      "properties": {
        "tr": {"type": "string", "maxLength": 10000},
        "en": {"type": "string", "maxLength": 10000},
        "ar": {"type": "string", "maxLength": 10000}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string", "enum": ["verified", "needs_review", "disputed", "provisional"]},
    "version": {"type": "integer"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "legacy_ids": {
      "type": "object",
      "properties": {
        "battle_id": {"type": ["integer", "string"]},
        "event_id": {"type": ["integer", "string"]},
        "salibiyyat_event_id": {"type": ["integer", "string"]},
        "diplomacy_id": {"type": ["integer", "string"]}
      }
    }
  }
}
